# =============================================================================
# TELEGRAM API CREDENTIALS (REQUIRED)
# =============================================================================
API_ID=12345678
API_HASH=your_api_hash_here
STRING_SESSION=your_string_session_here

# =============================================================================
# GROUP MONITORING (REQUIRED)
# =============================================================================
WATCH_GROUP=your_group_username_or_id

# =============================================================================
# CHANNEL MONITORING (Optional)
# Leave empty to disable, or set to channel username/ID to monitor
# =============================================================================
WATCH_CHANNEL=

# =============================================================================
# RATE LIMITING SETTINGS (IMPORTANT FOR ACCOUNT SAFETY)
# =============================================================================
MIN_STORY_DELAY=300  # Minimum seconds between stories (5 minutes)
MAX_STORIES_PER_HOUR=5  # Maximum stories per hour
MAX_STORIES_PER_DAY=30  # Maximum stories per day
COOLDOWN_HOURS=1  # Hours to wait after hitting daily limit

# =============================================================================
# CAPTION SETTINGS
# =============================================================================
MIN_CAPTION_GAP=3  # Minimum captions before repeat

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
